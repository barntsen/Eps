#!/usr/bin/env python3
''' elc is a script for loading eps object files
    generated by the nvcc cuda compiler.

'''
import os
import sys

pyflag=False
for arg in sys.argv[1:] :
  if arg == '-shared' :
    if pyflag == False :
       pyflag = True

args=" "
arg=" "
for arg in sys.argv[1:] :
  arg = " "+arg+" " 
  args = args+arg

if(pyflag == True) :
  cmdline ="nvcc "+args+"$EPS/Lib/libecuda.o $EPS/Lib/runcuda.o $EPS/Lib/pyeps.o" 
else :
  cmdline ="nvcc "+args+"$EPS/Lib/libecuda.o $EPS/Lib/runcuda.o " 

print(cmdline)
os.system(cmdline)





