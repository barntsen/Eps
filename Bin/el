#!/usr/bin/env python3
''' el is a script for loading eps object files
    generated by the gcc c compiler or nvcc cuda compiler.
    
'''
import os
import sys

argv=""
pyflag=False
cudaflag = False
args=" "
arg=" "

if len(sys.argv) == 1 :
    print("usage  : el options files") 
    print("  options: ") 
    print("  -shared:  Create shared library") 
    print("  -cuda  :  Link cuda object files")
    exit()

# The logic below sets the pyflag as True if the "-shared"
# option is present. 
# The cudaflag is set to True if the "-cuda" option
# is present. 
# The cuda option is removed from the command line, 
# but the shared option is passed to the linker.

for arg in sys.argv[1:] :
  if arg == '-shared' :
    if pyflag == False :
       pyflag = True
    args = args+arg
  elif arg == "-cuda" :
    if cudaflag == False :
      cudaflag = True
  else:
    args = args + " " + arg
  
# If cudaflag is True link with nvcc (cuda), otherwise link with gcc (c) 
# If pyflag is true link also the pyeps.o file

if cudaflag == True:
  if(pyflag == True) :
    lib=" $EPS/Lib/libecuda.o $EPS/Lib/runcuda.o $EPS/Lib/pyeps.o" 
    cmdline ="nvcc " + args + lib
  else :
    lib=" $EPS/Lib/libecuda.o $EPS/Lib/runcuda.o " 
    cmdline ="nvcc " + args + lib
else :
  if(pyflag == True) :
    lib=" $EPS/Lib/libecpu.o $EPS/Lib/runcpu.o $EPS/Lib/pyeps.o" 
    cmdline ="nvcc "  + args + lib
  else :
    lib=" $EPS/Lib/libecpu.o $EPS/Lib/runcpu.o " 
    cmdline ="nvcc " + args + lib
print(cmdline)
#os.system(cmdline)





