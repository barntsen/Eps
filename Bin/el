#!/usr/bin/env python3
''' el is a script for loading eps object files

'''
import os
import sys

pyflag=False
for arg in sys.argv[1:] :
  if arg == '-shared' :
    if pyflag == False :
       pyflag = True

args=" "
arg=" "
for arg in sys.argv[1:] :
  arg = " "+arg+" " 
  args = args+arg

if(pyflag == True) :
  cmdline ="gcc "+args+"$EPS/Lib/libecpu.o $EPS/Lib/runcpu.o $EPS/Lib/pyeps.o $EPS/Lib/pyepsc.o" 
else :
  cmdline ="gcc "+args+"$EPS/Lib/libecpu.o $EPS/Lib/runcpu.o " 

print(cmdline)
os.system(cmdline)





